# Cloudflare Pages — Cache Control
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable
/*.html
  Cache-Control: public, max-age=0, must-revalidate
/*.css
  Cache-Control: public, max-age=0, must-revalidate
/*.js
  Cache-Control: public, max-age=0, must-revalidate
